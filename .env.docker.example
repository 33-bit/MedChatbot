# Copy values into .env. Do not commit real secrets.

# FastAPI debug API
CHAT_API_KEY=replace-me

# LLM
LLM_API_KEY=replace-me
BASE_URL=https://api.openai.com/v1
MODEL=gpt-4.1
FAST_MODEL=gpt-4.1-mini
GUARDRAIL_MODEL=gpt-4.1-mini

# Retrieval and storage services
QDRANT_URL=replace-me
QDRANT_API_KEY=replace-me
NEO4J_URI=bolt://replace-me:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-me
REDIS_URL=redis://replace-me:6379/0

# Telegram
TELEGRAM_BOT_TOKEN=replace-with-rotated-token
TELEGRAM_WEBHOOK_SECRET=replace-me
TELEGRAM_DROP_PENDING_UPDATES=true

# ngrok static endpoint. Do not include a trailing slash.
NGROK_AUTHTOKEN=replace-me
NGROK_URL=https://your-static-domain.ngrok-free.dev

# Startup tuning
WEBHOOK_REGISTRATION_DELAY_SECONDS=15
HF_PRELOAD_RETRIEVAL_MODELS=1
HF_PRELOAD_REQUIRED=0
