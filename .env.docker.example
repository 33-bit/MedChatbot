# Copy values into .env. Do not commit real secrets.

# FastAPI debug API
CHAT_API_KEY=

# LLM
LLM_API_KEY=
BASE_URL=
MODEL=
FAST_MODEL=
GUARDRAIL_MODEL=

# Retrieval and storage services
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_PORT=6334
HEALTH_INSURANCE_COLLECTION=health_insurance_law
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-this-local-neo4j-password
NEO4J_HTTP_PORT=7475
NEO4J_BOLT_PORT=7688
REDIS_URL=redis://redis:6379/0

# Conversation context (Redis-only, session-scoped) and the
# IPS-inspired user-managed medical profile (durable SQLite).
CONVERSATION_CONTEXT_ENABLED=1
PROFILE_READ_ENABLED=0
PROFILE_WRITE_ENABLED=0
PROFILE_REQUIRE_CONSENT=1
# Generate with: openssl rand -base64 32
# Production values must come from a secret manager, not this file.
PROFILE_IDENTITY_ACTIVE_VERSION=v1
PROFILE_IDENTITY_HMAC_KEY=
PROFILE_IDENTITY_PREVIOUS_VERSIONS=
PROFILE_DEFAULT_TENANT_ID=default
# Family (third-party) profile facts keep a short auto-expiry until the
# user explicitly confirms them; superseded profile rows are pruned after
# this many seconds.
PROFILE_THIRD_PARTY_TTL_SECONDS=1209600
PROFILE_SUPERSEDED_RETENTION_SECONDS=2592000
# Stable tenant identifier; never use the API-key secret.
CHAT_API_TENANT_ID=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_DROP_PENDING_UPDATES=true
# Numeric Telegram user ids allowed to run admin commands (comma-separated).
# Send /whoami to the bot to get yours.
TELEGRAM_ADMIN_IDS=

# Zalo
ZALO_BOT_TOKEN=
ZALO_WEBHOOK_SECRET=

# PayOS (VietQR top-up). Get keys from the PayOS dashboard.
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_BASE_URL=https://api-merchant.payos.vn
# Public URL for PayOS callbacks and citation PDF links.
# Register <PUBLIC_BASE_URL>/webhook/payos in PayOS.
PUBLIC_BASE_URL=

# ngrok static endpoint. Do not include a trailing slash.
NGROK_AUTHTOKEN=
NGROK_URL=

# Startup tuning
WEBHOOK_REGISTRATION_DELAY_SECONDS=15
HF_PRELOAD_RETRIEVAL_MODELS=1
HF_PRELOAD_REQUIRED=0
