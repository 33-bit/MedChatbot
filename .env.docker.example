# Copy values into .env. Do not commit real secrets.

# FastAPI debug API
CHAT_API_KEY=

# LLM
LLM_API_KEY=
BASE_URL=
MODEL=
FAST_MODEL=
GUARDRAIL_MODEL=

# Retrieval and storage services
QDRANT_URL=
QDRANT_API_KEY=
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=
REDIS_URL=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_DROP_PENDING_UPDATES=true

# ngrok static endpoint. Do not include a trailing slash.
NGROK_AUTHTOKEN=
NGROK_URL=

# Startup tuning
WEBHOOK_REGISTRATION_DELAY_SECONDS=15
HF_PRELOAD_RETRIEVAL_MODELS=1
HF_PRELOAD_REQUIRED=0
